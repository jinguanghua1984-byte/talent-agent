{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@github/ncc", "github.ts"]
    },
    "fs": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fs", "/workspace"]
    }
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ]
  },
  "skills": {
    "path": "./skills"
  }
}