{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JD Analysis Output",
  "type": "object",
  "required": ["core_skills", "raw_jd", "jd_hash"],
  "properties": {
    "core_skills": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "supplement_skills": {"type": "array", "items": {"type": "string"}, "default": []},
    "position_type": {"type": "string"},
    "experience_range": {"type": "array", "items": {"type": "integer"}, "minItems": 2, "maxItems": 2},
    "education_requirement": {"type": "string"},
    "industry_preference": {"type": "array", "items": {"type": "string"}, "default": []},
    "exclusion_criteria": {"type": "array", "items": {"type": "string"}, "default": []},
    "raw_jd": {"type": "string"},
    "jd_hash": {"type": "string"},
    "schema_version": {"type": "integer", "default": 1}
  }
}
