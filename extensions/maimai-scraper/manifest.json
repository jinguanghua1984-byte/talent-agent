{
  "manifest_version": 3,
  "name": "脉脉人选数据采集",
  "version": "2.4",
  "description": "脉脉人选数据采集工具 — 被动拦截 + 人选列表逐页采集 + 批量详情 + 数据导出",
  "permissions": ["storage", "scripting", "downloads"],
  "host_permissions": [
    "*://maimai.cn/*",
    "*://*.maimai.cn/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "脉脉人选数据采集"
  },
  "web_accessible_resources": [
    {
      "resources": ["automation.html", "automation.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["*://maimai.cn/*", "*://*.maimai.cn/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://maimai.cn/*", "*://*.maimai.cn/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
